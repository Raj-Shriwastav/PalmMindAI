# ==============================================================================
# PalmMind AI — Environment Configuration Template (.env.example)
# ==============================================================================
# Copy this file to '.env' and fill in your actual infrastructure credentials.
#
#   $ cp .env.example .env
#
# This file is used for:
#   1. Running application modules & services locally on the host machine.
#   2. Local unit/integration testing suites.
#
# Note: Docker Compose overrides these dynamically with container-internal hostnames
# (e.g. postgres, redis, qdrant, host.docker.internal) using defaults when starting
# the full-stack container services.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. PostgreSQL Database Configuration
# ------------------------------------------------------------------------------
# Persistent relational storage for document metadata, raw chunks, and bookings.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=palmmind_db
POSTGRES_HOST=localhost          # Use 'postgres' when running inside Docker Compose
POSTGRES_PORT=5432

# ------------------------------------------------------------------------------
# 2. Redis Cache & Memory Configuration
# ------------------------------------------------------------------------------
# Production-grade caching and state persistence (checkpoints) for LangGraph agent.
REDIS_HOST=localhost             # Use 'redis' when running inside Docker Compose
REDIS_PORT=6379

# ------------------------------------------------------------------------------
# 3. Qdrant Vector Database Configuration
# ------------------------------------------------------------------------------
# Local vector search engine for storing and querying text embeddings.
QDRANT_HOST=localhost            # Use 'qdrant' when running inside Docker Compose
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=palmmind_rag

# ------------------------------------------------------------------------------
# 4. LLM Server Configuration (llama.cpp)
# ------------------------------------------------------------------------------
# The FastAPI backend communicates with a local GPU-accelerated llama.cpp server.
# Ensure your model (e.g., Qwen3.5-4B-GGUF) is downloaded and running on port 8080.
LLM_BASE_URL=http://localhost:8080/v1   # Use 'http://host.docker.internal:8080/v1' inside Docker
LLM_API_KEY=not-needed                  # Local server does not require authentication
LLM_MODEL_NAME=Qwen3.5-4B-Q4_K_S.gguf

# ------------------------------------------------------------------------------
# 5. Embeddings Model Configuration
# ------------------------------------------------------------------------------
# The semantic search engine uses FastEmbed to generate text embeddings locally.
EMBEDDING_MODEL_NAME=Snowflake/snowflake-arctic-embed-m  # 768-dimensional embeddings

# ------------------------------------------------------------------------------
# 6. SMTP Email Notification Configuration (Optional)
# ------------------------------------------------------------------------------
# The booking tool sends transactional emails upon successful scheduling.
# Leave SMTP_HOST empty to fallback to a fully functional console-logging mock email service.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SENDER=
